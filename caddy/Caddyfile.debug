        header_up X-Trapper-Forwarded-Host {vars.original_host}
        header_up X-Trapper-Forwarded-Proto {vars.original_proto}
    }
}

handle_path {$TRAPPER_CS_BASE_HREF:/}* {
    root * /srv
    try_files {path} /index.html
    header Cache-Control "no-cache"
    replace "<base href=\"/\">" "<base href=\"{$TRAPPER_CS_BASE_HREF:/}\">"
    file_server
}
